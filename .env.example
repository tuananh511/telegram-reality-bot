# Copy file này thành .env và điền giá trị thật, hoặc export trực tiếp
# các biến này trong shell / crontab / systemd unit.
# KHÔNG commit file .env thật lên Git.

# --- Bắt buộc ---
BOT_TOKEN=123456:your-telegram-bot-token
CHAT_ID=your-telegram-chat-id
GEMINI_API_KEY=your-gemini-api-key

# --- Tuỳ chọn (đã có giá trị mặc định hợp lý) ---

# Model Gemini dùng để sinh/chấm điểm quote
GEMINI_MODEL=gemini-2.0-flash-001

# Đường dẫn file lưu lịch sử quote đã gửi (để chống trùng)
USED_MESSAGES_PATH=used_messages.json

# Khung giờ KHÔNG gửi quote (giờ local, theo UTC_OFFSET_HOURS), dạng 0-23.
# Ví dụ mặc định: từ 23h tới 8h sáng hôm sau sẽ không gửi.
SLEEP_HOUR_START=23
SLEEP_HOUR_END=8

# Múi giờ dùng để tính "giờ local", lệch so với UTC (VN = 7)
UTC_OFFSET_HOURS=7

# Xác suất gửi quote mỗi lần script được chạy (0.0 - 1.0).
# 0.25 nghĩa là ~25% số lần chạy sẽ thực sự gửi, phần còn lại bỏ qua.
# Kết hợp với tần suất chạy cron để kiểm soát số lượng tin nhắn/ngày.
SEND_PROBABILITY=0.25

# Điểm tối thiểu (do AI tự chấm) để một quote được gửi
MIN_SCORE=8

# Số lượng quote tối đa giữ lại trong lịch sử chống trùng
MAX_HISTORY=1000

# Timeout (giây) cho request tới Telegram API
REQUEST_TIMEOUT=20

# Số lần retry khi gọi Gemini API bị lỗi
MAX_RETRIES=2

# Mức log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
